VITE_API_URL=http://localhost:5030/api

# NOTE: Never place Firebase service-account JSON/private keys in frontend env files.
# Frontend uses only public Firebase web config values (below).
VITE_FIREBASE_API_KEY=replace-with-your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-with-sender-id
VITE_FIREBASE_APP_ID=replace-with-app-id

VITE_FIREBASE_VAPID_KEY=replace-with-your-web-push-vapid-key
