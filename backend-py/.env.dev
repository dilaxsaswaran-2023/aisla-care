DATABASE_URL=postgresql://postgres:1234@localhost:5432/aisla-db
JWT_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:8030
PORT=5030
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# Optional Firebase failure controls:
# FIREBASE_RETRY_COOLDOWN_SECONDS=120
# FIREBASE_AUTH_ERROR_COOLDOWN_SECONDS=900
# FIREBASE_WRITE_TIMEOUT_SECONDS=8

# Twilio credentials - fill in your values from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-your-twilio-auth-token
TWILIO_FROM_NUMBER=+10000000000

AZURE_OPENAI_API_KEY=replace-with-your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://senzmate-demos-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_GPT5_NANO_DEPLOYMENT=gpt-5-nano
