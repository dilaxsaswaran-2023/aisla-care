DATABASE_URL=postgresql://username:password@localhost:5432/your-db-name
JWT_SECRET=replace-with-strong-jwt-secret
CORS_ORIGIN=http://localhost:8030
PORT=5030
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# Optional Firebase failure controls:
# FIREBASE_RETRY_COOLDOWN_SECONDS=120
# FIREBASE_AUTH_ERROR_COOLDOWN_SECONDS=900
# FIREBASE_WRITE_TIMEOUT_SECONDS=8

# Twilio credentials - fill in your values from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-your-twilio-auth-token
TWILIO_FROM_NUMBER=+10000000000

AZURE_OPENAI_API_KEY=replace-with-your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_GPT5_NANO_DEPLOYMENT=your-gpt-5-nano-deployment-name
